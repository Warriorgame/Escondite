VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-public-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# WebRTC voice calls TURN config
# Fallback configured by default in code, but production should use your own TURN credentials.
VITE_TURN_URLS="turn:openrelay.metered.ca:80,turn:openrelay.metered.ca:443,turn:openrelay.metered.ca:443?transport=tcp,turns:openrelay.metered.ca:443?transport=tcp"
VITE_TURN_USERNAME="openrelayproject"
VITE_TURN_CREDENTIAL="openrelayproject"

# Local open-source AI for HideGround assistant
VITE_GEMMA_MODEL="gemma3:1b"
VITE_OLLAMA_URL="http://127.0.0.1:11434"
